NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
MYSQL_HOST=your_db_host
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=your_db_name
MYSQL_SSL=false
JWT_SECRET=replace_me_with_very_strong_secret
JWT_REFRESH_SECRET=replace_me_with_very_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
PYTHON_WORKER_URL=http://127.0.0.1:8001
ADMIN_SECRET=replace_me_with_admin_secret
ALLOW_CLIENT_DB_CONFIG=false
